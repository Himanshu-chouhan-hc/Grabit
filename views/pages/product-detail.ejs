<%- layout('layouts/boilerplate') %>

<div class="product-detail-container">
  <div class="product-detail-content">
    <div class="product-image-section">
      <div class="main-image">
        <img id="mainImage" src="<%= product.image %>" alt="<%= product.name %>" />
      </div>
      <div class="image-gallery">
        <img src="<%= product.image %>" onclick="changeImage(this)" class="gallery-thumb active" />
      </div>
    </div>

    <div class="product-details-section">
      <h1><%= product.name %></h1>
      <p class="product-description"><%= product.description %></p>

      <div class="rating-section">
        <span class="stars"><%- '★'.repeat(Math.floor(product.rating)) %>☆ <% if(product.rating % 1 !== 0) { %>★<% } %></span>
        <span class="review-count">(<%= product.reviews ? product.reviews.length : 0 %> Reviews)</span>
      </div>

      <div class="price-section">
        <div class="price-display">
          <span class="current-price">₹<%= product.price.toLocaleString() %></span>
          <span class="original-price">₹<%= product.originalPrice.toLocaleString() %></span>
          <span class="discount-percent"><%= product.discount %>% OFF</span>
        </div>
      </div>

      <div class="availability">
        <% if(product.stock > 0) { %>
          <span class="in-stock">In Stock</span>
          <span class="stock-count">Only <%= product.stock %> left</span>
        <% } else { %>
          <span class="out-of-stock">Out of Stock</span>
        <% } %>
      </div>

      <div class="highlights">
        <h3>Highlights</h3>
        <ul>
          <li>Category: <%= product.category %></li>
          <li>Authentic Product</li>
          <li>30 Days Return Policy</li>
          <li>Fast Shipping Available</li>
        </ul>
      </div>

      <div class="action-buttons">
        <button class="btn btn-cart" onclick="addToCart()">
          <i class="fas fa-shopping-cart"></i> Add to Cart
        </button>
        <button class="btn btn-wishlist">
          <i class="fas fa-heart"></i> Wishlist
        </button>
      </div>

      <div class="delivery-info">
        <h3>Delivery & Services</h3>
        <div class="info-item">
          <i class="fas fa-truck"></i>
          <div>
            <p>Delivery by Tomorrow</p>
            <span>Free delivery on orders above ₹500</span>
          </div>
        </div>
        <div class="info-item">
          <i class="fas fa-shield-alt"></i>
          <div>
            <p>Secure Transaction</p>
            <span>Your payment is protected</span>
          </div>
        </div>
        <div class="info-item">
          <i class="fas fa-undo"></i>
          <div>
            <p>Easy Returns</p>
            <span>Return within 30 days of delivery</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="reviews-section">
    <h2>Customer Reviews</h2>
    <div class="review-form">
      <h3>Write Your Review</h3>
      <div class="form-group">
        <label>Rating</label>
        <div class="rating-input">
          <% for(let i = 1; i <= 5; i++) { %>
            <label class="star-label">
              <input type="radio" name="rating" value="<%= i %>" />
              <i class="fas fa-star"></i>
            </label>
          <% } %>
        </div>
      </div>
      <div class="form-group">
        <label>Your Review</label>
        <textarea id="reviewText" placeholder="Share your experience..." rows="4"></textarea>
      </div>
      <button class="btn btn-submit-review" onclick="submitReview()">Submit Review</button>
    </div>

    <div id="reviewsList" class="reviews-list">
      <!-- Reviews will be loaded here -->
    </div>
  </div>
</div>

<style>
  .product-detail-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
  }

  .product-detail-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    background-color: white;
    padding: 24px;
    border-radius: 4px;
    margin-bottom: 32px;
  }

  .product-image-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .main-image {
    width: 100%;
    height: 400px;
    background-color: #f0f0f0;
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-gallery {
    display: flex;
    gap: 8px;
  }

  .gallery-thumb {
    width: 80px;
    height: 80px;
    border: 2px solid #e0e0e0;
    border-radius: 4px;
    cursor: pointer;
    object-fit: cover;
    transition: all 0.3s;
  }

  .gallery-thumb.active {
    border-color: #2874f0;
  }

  .gallery-thumb:hover {
    border-color: #2874f0;
  }

  .product-details-section h1 {
    font-size: 28px;
    margin-bottom: 12px;
    color: #212121;
  }

  .product-description {
    color: #666;
    font-size: 14px;
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .rating-section {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .stars {
    color: #fbc02d;
    font-size: 16px;
  }

  .review-count {
    color: #666;
    font-size: 14px;
  }

  .price-section {
    margin-bottom: 20px;
  }

  .price-display {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .current-price {
    font-size: 28px;
    font-weight: 600;
    color: #212121;
  }

  .original-price {
    font-size: 16px;
    color: #999;
    text-decoration: line-through;
  }

  .discount-percent {
    background-color: #388e3c;
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 14px;
  }

  .availability {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .in-stock {
    color: #388e3c;
    font-weight: 600;
  }

  .out-of-stock {
    color: #d32f2f;
    font-weight: 600;
  }

  .stock-count {
    color: #d32f2f;
    font-size: 12px;
  }

  .highlights {
    margin-bottom: 24px;
  }

  .highlights h3 {
    font-size: 16px;
    margin-bottom: 12px;
    color: #212121;
  }

  .highlights ul {
    list-style: none;
    padding: 0;
  }

  .highlights li {
    padding: 8px 0;
    color: #666;
    font-size: 14px;
    border-bottom: 1px solid #e0e0e0;
  }

  .action-buttons {
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
  }

  .btn {
    flex: 1;
    padding: 14px;
    border: none;
    border-radius: 4px;
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .btn-cart {
    background-color: #fb641b;
    color: white;
  }

  .btn-cart:hover {
    background-color: #e55100;
    box-shadow: 0 2px 8px rgba(251, 100, 27, 0.3);
  }

  .btn-wishlist {
    background-color: white;
    color: #fb641b;
    border: 2px solid #fb641b;
  }

  .btn-wishlist:hover {
    background-color: #fff5f0;
  }

  .delivery-info {
    background-color: #f8f9fa;
    padding: 16px;
    border-radius: 4px;
  }

  .delivery-info h3 {
    font-size: 14px;
    margin-bottom: 16px;
    color: #212121;
  }

  .info-item {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
  }

  .info-item i {
    color: #2874f0;
    font-size: 18px;
    min-width: 24px;
  }

  .info-item p {
    margin: 0;
    font-weight: 500;
    font-size: 14px;
    color: #212121;
  }

  .info-item span {
    display: block;
    font-size: 12px;
    color: #666;
  }

  .reviews-section {
    background-color: white;
    padding: 24px;
    border-radius: 4px;
  }

  .reviews-section h2 {
    font-size: 22px;
    margin-bottom: 20px;
    color: #212121;
  }

  .review-form {
    background-color: #f8f9fa;
    padding: 20px;
    border-radius: 4px;
    margin-bottom: 20px;
  }

  .review-form h3 {
    margin-bottom: 16px;
    color: #212121;
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-group label {
    display: block;
    margin-bottom: 8px;
    color: #212121;
    font-weight: 500;
  }

  .rating-input {
    display: flex;
    gap: 8px;
  }

  .star-label {
    font-size: 24px;
    color: #ddd;
    cursor: pointer;
    transition: color 0.3s;
  }

  .star-label:hover {
    color: #fbc02d;
  }

  .star-label input[type="radio"] {
    display: none;
  }

  .star-label input[type="radio"]:checked ~ i {
    color: #fbc02d;
  }

  .form-group textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    font-size: 14px;
    font-family: inherit;
    resize: vertical;
  }

  .btn-submit-review {
    background-color: #2874f0;
    color: white;
    padding: 12px 24px;
  }

  .btn-submit-review:hover {
    background-color: #1c51c6;
  }

  .reviews-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .review-card {
    border: 1px solid #e0e0e0;
    padding: 16px;
    border-radius: 4px;
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .review-author {
    font-weight: 600;
    color: #212121;
  }

  .review-rating {
    color: #fbc02d;
  }

  .review-date {
    color: #999;
    font-size: 12px;
  }

  .review-text {
    color: #666;
    font-size: 14px;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .product-detail-content {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .action-buttons {
      flex-direction: column;
    }
  }
</style>

<script>
  function changeImage(img) {
    document.getElementById('mainImage').src = img.src;
    document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('active'));
    img.classList.add('active');
  }

  function loadReviews() {
  const reviewsList = document.getElementById('reviewsList');
  const reviews = <%- JSON.stringify(product.reviews || []) %>;
  
  // Login user ki detail nikalna
  const currentUser = JSON.parse(localStorage.getItem('user') || '{}');
  
  if (!reviews || reviews.length === 0) {
    reviewsList.innerHTML = '<p style="padding: 20px; text-align: center; color: #999;">No reviews yet.</p>';
    return;
  }

  reviewsList.innerHTML = reviews.map(review => {
    // Check: Kya ye review usi user ka hai jo abhi login hai?
    const isOwner = currentUser.id === review.reviewerId || currentUser._id === review.reviewerId;

    return `
      <div class="review-item" style="padding: 16px; border-bottom: 1px solid #e0e0e0; display: flex; gap: 16px;">
        <div style="flex-shrink: 0;">
          ${review.reviewerImage ? 
            `<img src="${review.reviewerImage}" style="width: 48px; height: 48px; border-radius: 50%; object-fit: cover;" />` :
            `<div style="width: 48px; height: 48px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center;"><i class="fas fa-user"></i></div>`
          }
        </div>
        <div style="flex: 1;">
          <div style="display: flex; align-items: center; justify-content: space-between;">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
              <strong>${review.reviewer || 'Anonymous'}</strong>
              <span style="color: #fb641b;">
                ${'★'.repeat(review.rating)}${'☆'.repeat(5 - review.rating)}
              </span>
            </div>
            
            ${isOwner ? `
              <button onclick="deleteReview('${review._id}')" style="background:none; border:none; color:#999; cursor:pointer;">
                <i class="fas fa-trash-alt"></i>
              </button>
            ` : ''}
          </div>
          <p style="color: #666; margin: 8px 0; font-size: 14px;">${review.comment}</p>
          <small style="color: #999;">${new Date(review.date).toLocaleDateString()}</small>
        </div>
      </div>
    `;
  }).join('');
}

async function deleteReview(reviewId) {
  if (!confirm('you want to delete review')) return;

  const token = localStorage.getItem('token');
  const productId = '<%= product._id %>';

  try {
    const response = await fetch(`/api/products/${productId}/review/${reviewId}`, {
      method: 'DELETE',
      headers: {
        'Authorization': `Bearer ${token}` // Security ke liye token
      }
    });

    const data = await response.json();

    if (data.success) {
      alert('Review was deleted successfully.');
      location.reload(); // Page refresh karein taaki update dikhe
    } else {
      alert('Error: ' + data.message);
    }
  } catch (err) {
    alert('Server error: Review delete nahi ho paya.');
  }
}

  function addToCart() {
    const cart = JSON.parse(localStorage.getItem('cart')) || [];
    const product = {
      productId: '<%= product._id %>',
      name: '<%= product.name %>',
      price: <%= product.price %>,
      image: '<%= product.image %>',
      quantity: 1,
    };

    const existing = cart.find(item => item.productId === product.productId);
    if (existing) {
      existing.quantity += 1;
    } else {
      cart.push(product);
    }

    localStorage.setItem('cart', JSON.stringify(cart));
    updateCartCount();
    
    // Show success message
    const btn = event.target.closest('button');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-check"></i> Added to Cart!';
    btn.style.backgroundColor = '#28a745';
    
    setTimeout(() => {
      btn.innerHTML = originalText;
      btn.style.backgroundColor = '';
    }, 2000);
  }

  function submitReview() {
    const rating = document.querySelector('input[name="rating"]:checked')?.value;
    const comment = document.getElementById('reviewText').value;

    if (!rating || !comment) {
      alert('Please fill all fields');
      return;
    }

    const token = localStorage.getItem('token');
    if (!token) {
      window.location.href = '/auth';
      return;
    }

    const user = JSON.parse(localStorage.getItem('user'));

    console.log('Submitting review:', { rating, comment, reviewer: user.name });

    fetch('/api/products/<%= product._id %>/review', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`,
      },
      body: JSON.stringify({ 
        rating: parseInt(rating), 
        comment, 
        reviewer: user.name || 'User',
        reviewerId: user.id,
        reviewerImage: user.profileImage
      }),
    })
      .then(r => r.json())
      .then(data => {
        console.log('Review submission response:', data);
        if (data.success) {
          alert('Review submitted! Reloading...');
          // Wait a moment then reload to fetch updated product
          setTimeout(() => {
            location.reload();
          }, 500);
        } else {
          alert('Failed: ' + (data.message || 'Unknown error'));
        }
      })
      .catch(err => {
        console.error('Review submission error:', err);
        alert('Error: ' + err.message);
      });
  }

  function updateCartCount() {
    const cart = JSON.parse(localStorage.getItem('cart')) || [];
    const cartBadge = document.querySelector('.cart-count');
    if (cartBadge) {
      const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
      cartBadge.textContent = totalItems;
      cartBadge.style.display = totalItems > 0 ? 'block' : 'none';
    }
  }

  

  // Initialize
  document.addEventListener('DOMContentLoaded', function() {
    loadReviews();
    updateCartCount();
  });
</script>
