<%- layout('layouts/boilerplate') %>



  <div class="features-container">
    <a href="/Mobiles" class="f-card-item">
      <div class="f-card-item">
        <img src="https://th.bing.com/th/id/OIP.YgMdB1OTpldRP7-LBqz-uAHaHa?w=139&h=180&c=7&r=0&o=7&dpr=1.3&pid=1.7&rm=3"
          alt="Mobiles " class="f-card-icon" href="" />
        <h2>Mobiles</h2>
      </div>
    </a>
    <a href="/Furniture" class="f-card-item">
    <div class="f-card-item">
      <img src="https://th.bing.com/th/id/OIP._KxxBOlWhHVgl3OtzoV8KgHaGt?w=214&h=194&c=7&r=0&o=7&dpr=1.3&pid=1.7&rm=3"
        alt Furniture class="f-card-icon" />
      <h2>Furniture</h2>
    </div>
  </a>
    <a href="/Fashion"class="f-card-item">
      <div class="f-card-item">
        <img src="https://th.bing.com/th/id/OIP.vXraDVCmQ8bTS7sXcOLZCgHaLG?w=204&h=306&c=7&r=0&o=7&dpr=1.3&pid=1.7&rm=3"
          alt="Fashion" class="f-card-icon" />
        <h2>Fashion</h2>
      </div>
    </a>
    <a href="/appliances" class="f-card-item">
    <div class="f-card-item">
      <img
        src="data:image/webp;base64,"
        alt="Appliances" class="f-card-icon" />
      <h2>Appliances</h2>
    </div>
    </a>
    <a href="/electronics" class="f-card-item">
    <div class="f-card-item">
      <img src="https://tse4.mm.bing.net/th/id/OIP.zSgviJvhu5p0h-Cu7ttikAHaEc?rs=1&pid=ImgDetMain&o=7&rm=3"
        alt="Electronics" class="f-card-icon" />
      <h2>Electronics</h2>
    </div>
    </a>
    <a href="/beauty-toys"class="f-card-item">
    <div class="f-card-item">
      <img src="https://i.pinimg.com/originals/72/85/24/7285248dbf46bc8a9025bd58f916540a.jpg" alt="Beauty & Toys"
        class="f-card-icon" />
      <h2>Beauty & Toys</h2>
    </div>
    </a>
    <a href="/grocery" class="f-card-item">
    <div class="f-card-item">
      <img
        src="https://static.vecteezy.com/system/resources/previews/025/379/737/original/creative-grocery-store-logo-with-a-shop-basket-design-concept-illustration-symbol-icon-vector.jpg"
        alt="Grocery" class="f-card-icon" />
      <h2>Grocery</h2>
    </div>
    </a>
  </div>
  <div class="slider-container">
    <div class="slider-wrapper">
        <% for(let feature of features){ %>
          
          <img src="<%= feature.url %>" alt="feature" />
          
        <% } %>
    </div>
    <button class="arrow prev" onclick="prevSlide()">&#10094;</button>
    <button class="arrow next" onclick="nextSlide()">&#10095;</button>
    <div class="slider-dots">
        <% for(let i = 0; i < features.length; i++){ %>
          <span class="slider-dot <%= i === 0 ? 'active' : '' %>" onclick="goToSlide('<%= i %>')"></span>
        <% } %>
    </div>
  </div>

  <!-- Best Deals Section -->
  <div class="deals-section">
    <div class="section-header">
      <h2>Best Deals</h2>
      <a href="#" class="view-all">View All</a>
    </div>
    <div class="products-grid">
      <% if(bestDeals && bestDeals.length > 0) { %>
        <% bestDeals.forEach(product => { %>
          <div class="product-card" onclick="goToProduct('<%= product._id %>')">
            <div class="product-image">
              <img src="<%= product.image %>" alt="<%= product.name %>" />
              <div class="discount-badge">-<%= product.discount %>%</div>
            </div>
            <div class="product-info">
              <h3 class="product-name"><%= product.name %></h3>
              <div class="product-rating">
                <span class="stars"><%- '★'.repeat(Math.floor(product.rating)) %>☆ <% if(product.rating % 1 !== 0) { %>★<% } %></span>
                <span class="review-count">(<%= product.reviews ? product.reviews.length : 0 %> reviews)</span>
              </div>
              <div class="product-price">
                <span class="current-price">₹<%= product.price.toLocaleString() %></span>
                <span class="original-price">₹<%= product.originalPrice.toLocaleString() %></span>
              </div>
              <button class="add-to-cart-btn" onclick="addProductToCart(event, '<%= product._id %>', '<%= product.name %>', '<%= product.price %>' , '<%= product.image %>')"><i class="fas fa-shopping-cart"></i> Add to Cart</button>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Flash Deals Section -->
  <div class="flash-deals-section">
    <div class="section-header">
      <h2>⚡ Flash Deals</h2>
      <span class="timer">Ends in: 02:45:30</span>
    </div>
    <div class="flash-products-grid">
      <% if(flashDeals && flashDeals.length > 0) { %>
        <% flashDeals.forEach(product => { %>
          <div class="flash-product-card" onclick="goToProduct('<%= product._id %>')">
            <div class="flash-image">
              <img src="<%= product.image %>" alt="<%= product.name %>" />
              <div class="flash-badge">FLASH</div>
            </div>
            <div class="flash-info">
              <h4><%= product.name %></h4>
              <div class="flash-rating">
                <span class="stars"><%- '★'.repeat(Math.floor(product.rating)) %>☆ <% if(product.rating % 1 !== 0) { %>★<% } %></span>
              </div>
              <div class="flash-price-section">
                <span class="flash-price">₹<%= product.price.toLocaleString() %></span>
                <span class="flash-original">₹<%= product.originalPrice.toLocaleString() %></span>
              </div>
              <div class="stock-bar">
                <div class="stock-fill" style="width: <%= Math.max(20, 100 - product.stock / 10) %>%"></div>
              </div>
              <p class="stock-text">Only <%= Math.max(10, 100 - product.stock) %> left</p>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-content">
      <div class="footer-section">
        <h4>About</h4>
        <ul>
          <li><a href="#">About Us</a></li>
