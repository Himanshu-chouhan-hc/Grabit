<%- layout('layouts/boilerplate') %>


<%- layout('layouts/boilerplate') %>

<%- layout('layouts/boilerplate') %>

<%- layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/css/category.css">

<div class="container-fluid mt-4">
  <div class="breadcrumb-nav mb-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb" style="background: transparent;">
        <li class="breadcrumb-item"><a href="/" style="text-decoration: none; color: #2874f0;">Home</a></li>
        <!-- <li class="breadcrumb-item active" aria-current="page"><%= category %></li> -->
      </ol>
    </nav>
  </div>

  <div class="row">
    <div class="col-lg-3">
      <!-- Sidebar Filters -->
      <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
          <h5 class="mb-0">Filters</h5>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label fw-bold">Price Range</label>
            <div class="d-flex gap-2">
              <input type="number" class="form-control form-control-sm" placeholder="Min" id="minPrice" />
              <input type="number" class="form-control form-control-sm" placeholder="Max" id="maxPrice" />
            </div>
            <button class="btn btn-sm btn-primary mt-2 w-100" onclick="filterByPrice()">Apply</button>
          </div>
          <hr>
          <div class="mb-3">
            <label class="form-label fw-bold">Rating</label>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="rating4" value="4" onchange="filterByRating()" />
              <label class="form-check-label" for="rating4">⭐⭐⭐⭐ & up</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="rating3" value="3" onchange="filterByRating()" />
              <label class="form-check-label" for="rating3">⭐⭐⭐ & up</label>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-9">
      <!-- Category Header -->
      <div style="background: linear-gradient(90deg, #2874f0 0%, #0a53be 100%); color: white; padding: 20px; border-radius: 4px; margin-bottom: 20px;">
        <h2 class="mb-0">
          <i class="fas fa-tag me-2"></i><%= category %>
        </h2>
        <small><%= products.length %> products available</small>
      </div>

      <% if(products.length > 0) { %>
      <!-- Products Grid -->
      <div class="products-grid">
        <% products.forEach(product => { %>
        <div class="product-card">
          <a href="/product/<%= product._id %>" style="text-decoration: none; color: inherit;">
            <div class="product-image">
              <img src="<%= product.image || 'https://via.placeholder.com/200' %>" alt="<%= product.name %>" />
              <% if(product.discount) { %>
              <div class="discount-badge"><%= product.discount %>% OFF</div>
              <% } %>
            </div>
          </a>

          <div class="product-info">
            <a href="/product/<%= product._id %>" style="text-decoration: none; color: inherit;">
              <h5 class="product-name"><%= product.name.substring(0, 30) %>...</h5>
            </a>

            <div class="product-rating">
              <% for(let i = 0; i < Math.floor(product.rating || 0); i++) { %>
                <i class="fas fa-star text-warning"></i>
              <% } %>
              <small class="text-muted">(<%= product.reviews ? product.reviews.length : 0 %> reviews)</small>
            </div>

            <div class="product-price">
              <span class="current-price">₹<%= product.price %></span>
              <% if(product.originalPrice) { %>
                <span class="original-price">₹<%= product.originalPrice %></span>
              <% } %>
            </div>

            <button class="add-to-cart-btn btn btn-primary btn-sm w-100 mt-2" onclick="addToCart('<%= product._id %>', '<%= product.name %>', '<%= product.price %>')">
              <i class="fas fa-shopping-cart me-1"></i> Add to Cart
            </button>
          </div>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <div class="alert alert-info text-center py-5">
        <i class="fas fa-inbox" style="font-size: 48px; color: #2874f0; margin-bottom: 20px; display: block;"></i>
        <h4>No products found in this category</h4>
        <p>Try browsing other categories or search for products</p>
        <a href="/" class="btn btn-primary mt-3">Back to Home</a>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script src="/js/category.js"></script>
